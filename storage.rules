rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    // Recipe photos: publicly readable; any authenticated user may upload an
    // image up to 10 MB. Delete is intentionally restricted to authenticated
    // users — the proper authorId-aware delete is a path migration tracked in
    // PLAN.md Phase 15 Step 4(2) and lands in a follow-up.
    match /recipes/{recipeId}/photos/{photo} {
      allow read: if true;
      allow write: if request.auth != null
        && request.resource.size < 10 * 1024 * 1024
        && request.resource.contentType.matches('image/.*');
      allow delete: if request.auth != null;
    }

    // Avatars: publicly readable; only the owning user may upload (≤ 5 MB,
    // image/* only) or delete their own avatar.
    match /avatars/{uid}/{fileName} {
      allow read: if true;
      allow write: if request.auth != null
        && request.auth.uid == uid
        && request.resource.size < 5 * 1024 * 1024
        && request.resource.contentType.matches('image/.*');
      allow delete: if request.auth != null && request.auth.uid == uid;
    }
  }
}
